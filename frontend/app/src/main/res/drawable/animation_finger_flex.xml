<?xml version="1.0" encoding="utf-8"?>
<animation-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:oneshot="false">
    
    <!-- Finger Flexion Animation - Making a Fist -->
    <!-- Fingers fully extended -->
    <item android:drawable="@drawable/finger_open" android:duration="1000" />
    <!-- Begin closing fingers -->
    <item android:drawable="@drawable/finger_closing" android:duration="600" />
    <!-- Continue closing -->
    <item android:drawable="@drawable/finger_closing" android:duration="400" />
    <!-- Fingers fully closed (loose fist) -->
    <item android:drawable="@drawable/finger_closed" android:duration="1000" />
    <!-- Begin opening fingers -->
    <item android:drawable="@drawable/finger_opening" android:duration="600" />
    <!-- Continue opening -->
    <item android:drawable="@drawable/finger_opening" android:duration="400" />
    <!-- Back to fully extended -->
    <item android:drawable="@drawable/finger_open" android:duration="500" />
    
</animation-list>