<?xml version="1.0" encoding="utf-8"?>
<animation-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:oneshot="false">
    
    <!-- Hip Abduction Animation - Side Leg Lifting -->
    <!-- Starting position (legs together) -->
    <item android:drawable="@drawable/hip_abduction_start" android:duration="1000" />
    <!-- Begin lifting leg sideways -->
    <item android:drawable="@drawable/hip_abduction_lifting" android:duration="700" />
    <!-- Continue lifting -->
    <item android:drawable="@drawable/hip_abduction_lifting" android:duration="500" />
    <!-- Leg fully abducted (lifted to side) -->
    <item android:drawable="@drawable/hip_abduction_raised" android:duration="1200" />
    <!-- Begin lowering leg -->
    <item android:drawable="@drawable/hip_abduction_lowering" android:duration="700" />
    <!-- Continue lowering -->
    <item android:drawable="@drawable/hip_abduction_lowering" android:duration="500" />
    <!-- Back to starting position -->
    <item android:drawable="@drawable/hip_abduction_start" android:duration="500" />
    
</animation-list>