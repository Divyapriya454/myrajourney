<?xml version="1.0" encoding="utf-8"?>
<animation-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:oneshot="false">
    
    <!-- Thumb Flexion/Extension Animation - Bending Thumb -->
    <!-- Thumb extended (starting position) -->
    <item android:drawable="@drawable/thumb_frame1" android:duration="1000" />
    <!-- Begin bending thumb toward palm -->
    <item android:drawable="@drawable/thumb_frame2" android:duration="600" />
    <!-- Continue bending -->
    <item android:drawable="@drawable/thumb_frame3" android:duration="500" />
    <!-- Thumb fully bent toward palm -->
    <item android:drawable="@drawable/thumb_frame4" android:duration="1000" />
    <!-- Begin straightening thumb -->
    <item android:drawable="@drawable/thumb_frame3" android:duration="500" />
    <!-- Continue straightening -->
    <item android:drawable="@drawable/thumb_frame2" android:duration="600" />
    <!-- Back to extended position -->
    <item android:drawable="@drawable/thumb_frame1" android:duration="500" />
    
</animation-list>