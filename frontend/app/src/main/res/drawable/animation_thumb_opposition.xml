<?xml version="1.0" encoding="utf-8"?>
<animation-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:oneshot="false">
    
    <!-- Thumb Opposition Animation - Touch Each Finger -->
    <!-- Starting position (thumb extended) -->
    <item android:drawable="@drawable/thumb_frame1" android:duration="800" />
    <!-- Touch index finger -->
    <item android:drawable="@drawable/thumb_frame2" android:duration="600" />
    <!-- Hold position -->
    <item android:drawable="@drawable/thumb_frame2" android:duration="400" />
    <!-- Touch middle finger -->
    <item android:drawable="@drawable/thumb_frame3" android:duration="600" />
    <!-- Hold position -->
    <item android:drawable="@drawable/thumb_frame3" android:duration="400" />
    <!-- Touch ring/pinky finger -->
    <item android:drawable="@drawable/thumb_frame4" android:duration="600" />
    <!-- Hold position -->
    <item android:drawable="@drawable/thumb_frame4" android:duration="400" />
    <!-- Return to starting position -->
    <item android:drawable="@drawable/thumb_frame3" android:duration="300" />
    <item android:drawable="@drawable/thumb_frame2" android:duration="300" />
    <item android:drawable="@drawable/thumb_frame1" android:duration="300" />
    
</animation-list>