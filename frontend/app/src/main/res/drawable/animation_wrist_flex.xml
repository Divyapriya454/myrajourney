<?xml version="1.0" encoding="utf-8"?>
<animation-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:oneshot="false">
    
    <!-- Wrist Flexion/Extension Animation - Smooth and Clear -->
    <!-- Neutral position -->
    <item android:drawable="@drawable/wrist_flex_frame1" android:duration="1000" />
    <!-- Transition to flexion -->
    <item android:drawable="@drawable/wrist_flex_frame2" android:duration="500" />
    <!-- Full flexion (up) -->
    <item android:drawable="@drawable/wrist_flex_frame3" android:duration="1000" />
    <!-- Transition back to neutral -->
    <item android:drawable="@drawable/wrist_flex_frame2" android:duration="500" />
    <!-- Back to neutral -->
    <item android:drawable="@drawable/wrist_flex_frame1" android:duration="500" />
    <!-- Transition to extension -->
    <item android:drawable="@drawable/wrist_flex_frame2" android:duration="500" />
    
</animation-list>