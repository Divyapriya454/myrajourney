    android:viewportWidth="120"
    android:viewportHeight="120">
    
    <!-- Hip Abduction Starting Position - Legs Together -->
    <!-- Body/Torso -->
    <path
        android:fillColor="#4CAF50"
        android:pathData="M40,20 L80,20 L80,60 L40,60 Z" />
    
    <!-- Left leg -->
    <path
        android:fillColor="#2196F3"
        android:pathData="M50,60 L55,60 L55,100 L50,100 Z" />
    
    <!-- Right leg (the one that will move) -->
    <path
        android:fillColor="#1976D2"
        android:pathData="M65,60 L70,60 L70,100 L65,100 Z" />
    
    <!-- Hip joints (circles as paths) -->
    <path
        android:fillColor="#FF5722"
        android:pathData="M52.5,58 A2,2 0 1,1 52.5,62 A2,2 0 1,1 52.5,58 Z" />
    <path
        android:fillColor="#FF5722"
        android:pathData="M67.5,58 A2,2 0 1,1 67.5,62 A2,2 0 1,1 67.5,58 Z" />
    
    <!-- Arrow indicating sideways movement -->
    <path
        android:fillColor="#FFC107"
        android:pathData="M75,70 L80,75 L85,70 L80,65 Z" />
        
</vector>