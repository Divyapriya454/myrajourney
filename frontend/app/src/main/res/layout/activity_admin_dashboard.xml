<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".admin.dashboard.AdminDashboardActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorBackground"
        android:fitsSystemWindows="true">

        <!-- TOP BAR -->
        <androidx.cardview.widget.CardView
            android:id="@+id/topBarCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:elevation="4dp"
            app:cardCornerRadius="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="?attr/colorPrimary"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/iconMenu"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_menu"
                        android:padding="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="@color/white" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Admin Dashboard"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:textColor="@color/white"
                        android:layout_marginStart="16dp"/>

                    <!-- Updated logout button -->
                    <ImageView
                        android:id="@+id/logoutBtn"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_logout"
                        android:padding="8dp"
                        android:background="@drawable/bg_logout_button"
                        android:contentDescription="Logout"/>
                </LinearLayout>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- MAIN CONTENT -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/mainScroll"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/topBarCard"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:fillViewport="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <!-- ACTIONS CARD -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/actionsCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:elevation="4dp"
                    app:cardCornerRadius="16dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="?attr/colorSurface"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quick Actions"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_marginBottom="16dp"/>

                        <!-- ORIGINAL BUTTONS (unchanged) -->
                        <Button
                            android:id="@+id/btnCreatePatient"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_button_primary"
                            android:text="➕ Create New Patient"
                            android:textColor="?attr/colorSurface"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:textAllCaps="false"
                            android:layout_marginBottom="12dp"/>

                        <Button
                            android:id="@+id/btnCreateDoctor"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_button_secondary"
                            android:text="➕ Create New Doctor"
                            android:textColor="?attr/colorSurface"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:textAllCaps="false"
                            android:layout_marginBottom="12dp"/>

                        <Button
                            android:id="@+id/btnAssignPatients"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_button_accent"
                            android:text="👥 Assign Patients to Doctors"
                            android:textColor="?attr/colorSurface"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:textAllCaps="false"
                            android:layout_marginBottom="12dp"/>

                        <Button
                            android:id="@+id/btnViewAllPatients"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_button_outline"
                            android:text="📋 View All Patients"
                            android:textColor="?attr/colorPrimary"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:textAllCaps="false"
                            android:layout_marginBottom="12dp"/>



                        <!-- USER MANAGEMENT BUTTON -->
                        <Button
                            android:id="@+id/btnManageUsers"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_button_warning"
                            android:text="👥 Manage Users (Delete)"
                            android:textColor="?attr/colorSurface"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:textAllCaps="false"/>


                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    app:layout_constraintTop_toBottomOf="@id/actionsCard"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/navDrawerContainer"
        android:layout_width="@dimen/nav_drawer_width"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="?attr/colorSurface"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:paddingTop="0dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Profile Section with Solid Blue Background -->
            <RelativeLayout
                android:id="@+id/nav_profile_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/primary_color"
                android:paddingStart="40dp"
                android:paddingEnd="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/nav_user_avatar"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_person_default"
                    android:background="@drawable/circle_background"
                    android:backgroundTint="@color/white"
                    android:padding="8dp"
                    android:layout_marginBottom="16dp"
                    android:contentDescription="Avatar" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_below="@id/nav_user_avatar">

                    <TextView
                        android:id="@+id/navHeaderAdminName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Admin"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/navHeaderAdminEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="admin@example.com"
                        android:textColor="@color/white"
                        android:alpha="0.9"
                        android:textSize="14sp" />
                </LinearLayout>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:paddingTop="8dp"
                android:paddingBottom="16dp">


            <!-- Menu Items - Only Dark Theme and Logout -->
            <TextView
                android:text="Preferences"
                style="@style/NavSectionHeader" />

            <LinearLayout
                android:id="@+id/menu_dark_theme"
                style="@style/NavMenuItemRow">
                <ImageView
                    android:src="@android:drawable/ic_menu_day"
                    style="@style/NavMenuItemIcon" />
                <TextView
                    android:text="Toggle Dark Theme"
                    style="@style/NavMenuItemText" />
            </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.drawerlayout.widget.DrawerLayout>
