<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?attr/android:windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- TOP BAR -->
        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="?attr/colorSurface"
            android:elevation="4dp">

            <ImageView
                android:id="@+id/menu_icon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_menu"
                android:contentDescription="@string/menu"
                android:background="@drawable/circle_background"
                android:padding="8dp" />

            <TextView
                android:id="@+id/toolbar_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Dashboard"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"
                android:textColor="?attr/colorOnSurface" />

            <!-- YOUR LOGOUT BUTTON -->
            <ImageView
                android:id="@+id/logoutBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_logout"
                android:padding="8dp"
                android:background="@drawable/bg_logout_button"
                android:contentDescription="Logout"/>

            <!-- NOTIFICATION BUTTON -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp">

                <ImageView
                    android:id="@+id/notificationsBtn"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_bell"
                    android:contentDescription="Notifications"
                    android:background="@drawable/circle_background"
                    android:padding="10dp" />

                <TextView
                    android:id="@+id/notifBadge"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="end|top"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="2dp"
                    android:background="@android:color/holo_red_dark"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:visibility="gone"
                    android:text="0"/>
            </FrameLayout>
        </LinearLayout>

        <!-- SCROLL CONTENT -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/mainScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- WELCOME -->
                <TextView
                    android:id="@+id/welcomeDoctorText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome, Doctor!"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginTop="8dp"/>

                <!-- QUICK ACTIONS - FIXED ALIGNMENT -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick Actions"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginTop="16dp"/>

                <!-- FIRST ROW OF BUTTONS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp"
                    android:gravity="center"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/btnNewPatient"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:drawableTop="@drawable/ic_add_circle"
                        android:text="NEW PATIENT"
                        android:textColor="@color/button_text_light"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:padding="8dp"
                        android:backgroundTint="@color/button_new_patient_bg"
                        android:drawablePadding="6dp" />

                    <Button
                        android:id="@+id/btnSchedule"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@color/button_schedule_bg"
                        android:drawableTop="@drawable/ic_rehab"
                        android:padding="8dp"
                        android:text="SCHEDULE"
                        android:textColor="@color/button_text_light"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:drawablePadding="6dp" />
                </LinearLayout>

                <!-- SECOND ROW OF BUTTONS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="4dp"
                    android:paddingBottom="8dp"
                    android:gravity="center"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/btnReports"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="@color/button_reports_bg"
                        android:drawableTop="@drawable/ic_report_sample"
                        android:drawablePadding="6dp"
                        android:padding="8dp"
                        android:text="REPORTS"
                        android:textColor="@color/button_text_light"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnAssignExercises"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:drawableTop="@drawable/ic_rehab"
                        android:text="MANAGE PATIENTS"
                        android:textColor="@color/button_text_light"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:padding="8dp"
                        android:backgroundTint="@color/button_new_patient_bg"
                        android:drawablePadding="6dp"/>
                </LinearLayout>

                <!-- NOTIFICATIONS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:id="@+id/notifications_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Notifications"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface" />

                    <ImageButton
                        android:id="@+id/btnRefreshNotifications"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_refresh"
                        android:background="@drawable/circle_background"
                        android:contentDescription="Refresh Notifications"
                        android:padding="8dp"
                        android:layout_marginEnd="8dp"
                        android:tint="?attr/colorPrimary" />

                    <TextView
                        android:id="@+id/view_all_notifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All"
                        android:textStyle="bold"
                        android:textColor="#0088FF" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/notifications_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    android:layout_marginTop="8dp"
                    android:minHeight="50dp"
                    android:background="#F0F0F0" />

                <!-- Notifications Empty State -->
                <TextView
                    android:id="@+id/notifications_empty_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No notifications available"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:gravity="center"
                    android:padding="20dp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

                <!-- APPOINTMENTS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:id="@+id/appointments_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Upcoming Appointments"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/view_all_appointments"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All"
                        android:textStyle="bold"
                        android:textColor="#0088FF"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/appointments_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    android:layout_marginTop="8dp"
                    android:minHeight="50dp"
                    android:background="#F0F0F0" />

                <!-- Appointments Empty State -->
                <TextView
                    android:id="@+id/appointments_empty_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No upcoming appointments"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:gravity="center"
                    android:padding="20dp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

                <!-- PATIENTS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:id="@+id/patients_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Patients Record"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/view_all_patients"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All"
                        android:textStyle="bold"
                        android:textColor="#0088FF"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/patients_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    android:layout_marginTop="8dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="88dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- BOTTOM NAV -->
        <LinearLayout
            android:id="@+id/bottom_navigation"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:background="?attr/colorSurface"
            android:elevation="8dp"
            android:padding="8dp">

            <LinearLayout
                android:id="@+id/bottom_dashboard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_menu" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dashboard"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bottom_patients"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_patient" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Patients"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bottom_schedule"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_rehab" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Schedule"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bottom_reports"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_report_sample" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reports"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- NAV DRAWER -->
    <!-- Custom Navigation Drawer replaces standard NavigationView -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/navDrawerContainer"
        android:layout_width="@dimen/nav_drawer_width"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="?attr/colorSurface"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:paddingTop="0dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Profile Section with Solid Blue Background -->
            <RelativeLayout
                android:id="@+id/nav_profile_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/primary_color"
                android:paddingStart="40dp"
                android:paddingEnd="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/nav_user_avatar"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_person_default"
                    android:background="@drawable/circle_background"
                    android:backgroundTint="@color/white"
                    android:padding="8dp"
                    android:layout_marginBottom="16dp"
                    android:contentDescription="Avatar" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_below="@id/nav_user_avatar">

                    <TextView
                        android:id="@+id/navHeaderDoctorName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Doctor"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/navHeaderDoctorEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="doctor@example.com"
                        android:textColor="@color/white"
                        android:alpha="0.9"
                        android:textSize="14sp" />
                </LinearLayout>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingEnd="0dp"
                android:paddingBottom="16dp"
                android:paddingStart="0dp">


            <!-- Menu Items -->
            <LinearLayout
                android:id="@+id/menu_add_patient"
                style="@style/NavMenuItemRow">
                <ImageView
                    android:src="@android:drawable/ic_menu_add"
                    style="@style/NavMenuItemIcon" />
                <TextView
                    android:text="Add Patient"
                    style="@style/NavMenuItemText" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menu_all_patients"
                style="@style/NavMenuItemRow">
                <ImageView
                    android:src="@android:drawable/ic_menu_myplaces"
                    style="@style/NavMenuItemIcon" />
                <TextView
                    android:text="All Patients"
                    style="@style/NavMenuItemText" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menu_schedule"
                style="@style/NavMenuItemRow">
                <ImageView
                    android:src="@android:drawable/ic_menu_agenda"
                    style="@style/NavMenuItemIcon" />
                <TextView
                    android:text="Schedule"
                    style="@style/NavMenuItemText" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menu_add_appointment"
                style="@style/NavMenuItemRow">
                <ImageView
                    android:src="@android:drawable/ic_input_add"
                    style="@style/NavMenuItemIcon" />
                <TextView
                    android:text="Add Appointment"
                    style="@style/NavMenuItemText" />
            </LinearLayout>



            <LinearLayout
                android:id="@+id/menu_reports"
                style="@style/NavMenuItemRow">
                <ImageView
                    android:src="@android:drawable/ic_menu_report_image"
                    style="@style/NavMenuItemIcon" />
                <TextView
                    android:text="Reports"
                    style="@style/NavMenuItemText" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menu_settings"
                style="@style/NavMenuItemRow">
                <ImageView
                    android:src="@android:drawable/ic_menu_preferences"
                    style="@style/NavMenuItemIcon" />
                <TextView
                    android:text="Settings"
                    style="@style/NavMenuItemText" />
            </LinearLayout>

            <TextView
                android:text="Preferences"
                style="@style/NavSectionHeader" />

            <LinearLayout
                android:id="@+id/menu_dark_theme"
                style="@style/NavMenuItemRow">
                <ImageView
                    android:src="@android:drawable/ic_menu_day"
                    style="@style/NavMenuItemIcon" />
                <TextView
                    android:text="Toggle Dark Theme"
                    style="@style/NavMenuItemText" />
            </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.drawerlayout.widget.DrawerLayout>
