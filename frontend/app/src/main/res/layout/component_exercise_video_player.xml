<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- YouTube Video WebView -->
    <WebView
        android:id="@+id/webViewVideo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:visibility="gone" />

    <!-- Animation/Image View (Fallback) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        
        <ImageView
            android:id="@+id/animationView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerInside"
            android:background="@color/black"
            android:contentDescription="Exercise demonstration"
            android:visibility="gone" />
        
        <!-- Floating Video Button -->
        <Button
            android:id="@+id/btnFloatingVideo"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="top|end"
            android:layout_margin="16dp"
            android:text="▶ Video"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:background="@drawable/bg_button_primary"
            android:paddingHorizontal="12dp"
            android:visibility="gone" />
            
    </FrameLayout>

    <!-- Video Overlay Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_overlay"
        android:padding="12dp">

        <TextView
            android:id="@+id/txtVideoTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Exercise Demonstration"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtVideoInstructions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Follow along with the demonstration"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Video Loading/Error State -->
    <LinearLayout
        android:id="@+id/layoutVideoError"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="@color/black"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_dumbbell"
            app:tint="@color/primary"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Exercise Instructions"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/txtErrorMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Follow the instructions below to perform the exercise"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textAlignment="center"
            android:lineSpacingExtra="4dp" />

        <Button
            android:id="@+id/btnTryVideo"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginTop="16dp"
            android:text="▶ Try Video"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:background="@drawable/bg_button_primary"
            android:paddingHorizontal="16dp"
            android:visibility="visible" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Watch the camera view below for motion tracking"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textAlignment="center"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</FrameLayout>