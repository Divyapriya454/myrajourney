<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="@drawable/item_bg"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical">

    <!-- Exercise Icon -->
    <ImageView
        android:id="@+id/imgExerciseIcon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_rehab"
        android:background="@drawable/circle_background"
        android:padding="12dp"
        app:tint="@color/primary" />

    <!-- Exercise Details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/txtExerciseName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wrist Flexion/Extension"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/txtExerciseCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wrist Exercise"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/txtExerciseDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gentle wrist movement to improve flexibility"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Difficulty Level -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Level: "
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/txtDifficultyLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Beginner"
                android:textSize="12sp"
                android:textColor="@color/success"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- Selection Checkbox -->
    <CheckBox
        android:id="@+id/checkboxSelect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp" />

</LinearLayout>